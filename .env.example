# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337

# ── Secrets (generate unique values for production) ─────────────────
# APP_KEYS: comma-sep 4 keys. Generate: openssl rand -base64 32 (x4)
APP_KEYS=change-me,change-me,change-me,change-me
# API_TOKEN_SALT: openssl rand -base64 32
API_TOKEN_SALT=change-me
# ADMIN_JWT_SECRET: openssl rand -base64 32
ADMIN_JWT_SECRET=change-me
# TRANSFER_TOKEN_SALT: openssl rand -base64 32
TRANSFER_TOKEN_SALT=change-me
# ENCRYPTION_KEY: openssl rand -base64 32
ENCRYPTION_KEY=change-me

# ── Database (PostgreSQL) ───────────────────────────────────────────
DATABASE_CLIENT=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=vyasta
DATABASE_PASSWORD=vyasta
DATABASE_SSL=false

# ── S3 Upload (SeaweedFS / S3-compatible) ───────────────────────────
AWS_ACCESS_KEY_ID=vyasta
AWS_ACCESS_SECRET=vyastapass
AWS_REGION=us-east-1
S3_ENDPOINT=http://storage:8333
S3_BUCKET=strapi-media
S3_PUBLIC_URL=http://localhost:8333/strapi-media

# ── Email ───────────────────────────────────────────────────────────
SMTP_HOST=maildev
SMTP_PORT=1025
EMAIL_FROM=Strapi <no-reply@example.com>

# ── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MCP ─────────────────────────────────────────────────────────────
ENABLE_MCP=false
MCP_AUTH_SECRET=change-me-in-production

# ── Admin User (auto-created on first bootstrap) ──────────────────
STRAPI_ADMIN_EMAIL=admin@strapi.local
STRAPI_ADMIN_PASSWORD=Admin123!
STRAPI_ADMIN_FIRSTNAME=Strapi
STRAPI_ADMIN_LASTNAME=Admin

# ── MCP ─────────────────────────────────────────────────────────────
ENABLE_MCP=false
MCP_TRANSPORT=sse
MCP_PORT=3001
MCP_AUTH_SECRET=change-me-in-production
MCP_ALLOWLIST=api::article.article,api::page.page,api::category.category,api::tag.tag
MCP_WRITE_ENABLED=false
MCP_RATE_LIMIT=60

# ── Sentry ──────────────────────────────────────────────────────────
SENTRY_DSN=
